# ============================================
# DS Financial Solutions - Environment Configuration
# ============================================
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control!
# ============================================

# --- Security: Generate strong secrets ---
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-long-change-this-immediately
ENCRYPTION_KEY=your-32-byte-encryption-key-exactly-32-chars

# --- Admin Portal ---
ADMIN_ID=TEAM EXCELLENT MINDS
ADMIN_PASSWORD=generate-a-strong-random-password

# --- Demo UPI MPIN (6 digits) ---
DEMO_MPIN=123456

# --- Dev/demo bypass (NEVER enable in production) ---
# ALLOW_DEV_AUTH_BYPASS=true
# DEV_AUTH_SECRET=another-strong-random-secret

# --- Server Configuration ---
PORT=5000
NODE_ENV=development

# --- CORS Origins (comma-separated for production) ---
# Example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# --- Database ---
DB_PATH=./data/financial.db

# --- AI Provider API Keys (optional) ---
# Get keys from respective providers
OPENROUTER_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# --- Payment: Razorpay (optional) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_BASIC=plan_basic_monthly
RAZORPAY_PLAN_PRO=plan_pro_monthly
RAZORPAY_PLAN_ENTERPRISE=plan_enterprise_monthly

# --- Redis (optional - for production caching) ---
REDIS_URL=redis://localhost:6379

# --- Email (optional - for notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@dsfinancial.in

# --- Logging ---
LOG_LEVEL=info

# --- SETU Account Aggregator (AA) Sandbox ---
# Get these values from your Setu Bridge dashboard.
# Product instance ID and API keys are created under FIU businesses.
SETU_AA_BASE_URL=https://fiu-sandbox.setu.co
SETU_AA_CLIENT_ID=
SETU_AA_CLIENT_SECRET=
SETU_AA_PRODUCT_INSTANCE_ID=
SETU_AA_REDIRECT_URL=https://your-frontend-url.github.io/aa/callback
SETU_PSB_FIP_ID=PSB-FIP-001
